# Core
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
TZ=Asia/Kolkata
DEFAULT_COUNTRY_CODE=+91
CURRENCY=INR

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/nahata

# Redis
REDIS_URL=redis://localhost:6379

# Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nahata-crm
S3_ACCESS_KEY=...
S3_SECRET_KEY=...

# Auth
JWT_ACCESS_SECRET=change_me_long_random_string
JWT_REFRESH_SECRET=change_me_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
SEED_OWNER_EMAIL=owner@nahatalawns.com
SEED_OWNER_PASSWORD=ChangeMe123!

# Provider selection: mock | meta | twilio | gupshup | exotel | deepgram | anthropic | openai
WHATSAPP_PROVIDER=mock
TELEPHONY_PROVIDER=mock
STT_PROVIDER=mock
LLM_PROVIDER=mock

# WhatsApp (Meta Cloud API)
# Meta Business Manager → WhatsApp Accounts → Phone Number ID
META_WABA_PHONE_NUMBER_ID=

# Meta App → Settings → Tokens (permanent token with whatsapp_business_messaging)
META_WABA_TOKEN=

# Custom webhook verification token (create your own, used during webhook setup)
META_WEBHOOK_VERIFY_TOKEN=nahata_webhook_verify_2024

# Meta App → Settings → Basic → App Secret (for HMAC signature verification)
META_APP_SECRET=

# Meta Graph API version (https://developers.facebook.com/docs/graph-api/changelog)
GRAPH_API_VERSION=v18.0

# Lead form delivery mode: "link" = web form URL, "flow" = WhatsApp Flow
LEAD_FORM_MODE=link

# URL to lead form when LEAD_FORM_MODE=link
LEAD_FORM_URL=http://localhost:5173/lead

# WhatsApp Flow ID when LEAD_FORM_MODE=flow (create in Meta Business Manager → Flows)
WHATSAPP_FLOW_ID=

# Stage Automation (send message when lead moves to a stage)
# Default: false (disabled to prevent unintended messages and 24h window violations)
# Set to true ONLY if you have configured StageMessageBinding templates and understand Meta's 24h window rule
WHATSAPP_STAGE_AUTOMATION_ENABLED=false

# Telephony (Exotel)
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=
EXOTEL_WEBHOOK_SECRET=

# STT (Deepgram)
DEEPGRAM_API_KEY=

# LLM (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_PROMPT_VERSION=v1

# Source webhook secrets
WEDMEGOOD_WEBHOOK_SECRET=
JUSTDIAL_WEBHOOK_SECRET=
GOOGLE_MAPS_WEBHOOK_SECRET=
WEBSITE_WEBHOOK_SECRET=

# Scoring
SCORE_HOT_THRESHOLD=80
SCORE_WARM_THRESHOLD=50
