{
  "name": "nahata-crm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter=backend --filter=frontend dev",
    "dev:api": "pnpm --filter=backend dev",
    "dev:web": "pnpm --filter=frontend dev",
    "build": "pnpm --filter=shared build && pnpm --filter=backend build && pnpm --filter=frontend build",
    "db:migrate": "pnpm --filter=backend db:migrate",
    "db:seed": "pnpm --filter=backend db:seed",
    "db:studio": "pnpm --filter=backend db:studio",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}

